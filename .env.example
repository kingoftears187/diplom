PORT=3000
NODE_ENV=production

# На хостинге задайте путь на постоянном диске, например:
# Render: /var/data/transnafta.db
# VPS: /var/www/transnafta/data/transnafta.db
DATABASE_PATH=./transnafta.db

# Обязательно смените перед публикацией
ADMIN_PANEL_USER=admin
ADMIN_PANEL_PASSWORD=change-this-password
